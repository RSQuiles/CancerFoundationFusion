{
  "experiment_name": "base_comparison_ablation",
  "output_dir": "ablation_runs/base_comparison",
  "dry_run": false,
  "train_entrypoint": "pretrain:main",
  "base_config": {
    "trainer": {
      "gpus": 2,
      "num_workers": 4,
      "precision": "bf16-mixed",
      "strategy": "ddp",
      "epochs": 10,
      "seed": 0,
      "val_check_interval": 0.5,
      "log_interval": 50,
      "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison",
      "wandb_entity": "rquiles",
      "wandb": "ablation_base_comparison",
      "compile": true,
      "ckpt-every-n-steps": 50000,
      "resume_from_checkpoint": "last"
    },
    "data": {
      "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready",
      "conditions": ["tissue_general", "assay"],
      "zero_percentages": [0.2, 0.4, 0.6],
      "bulk_ratio": 0.6,
      "pb_ratio": 0.3,
      "n_sc_per_pseudobulk": 10,
      "pb_group_column": "tissue_general",
      "trunc_by_sample": true,
      "balanced_sampler": true,
      "balanced_labels": ["tissue_general", "assay"]
    },
    "model": {
      "nlayers": 6,
      "nheads": 8,
      "embsize": 128,
      "d_hid": 256,
      "lr": 0.0001,
      "warmup_ratio_or_step": 10000,
      "max_seq_len": 600,
      "batch_size": 32,
      "input_style": "binned",
      "loss": "mse",
      "training_tasks": "both",
      "do_mvc": true,
      "where_condition": "none",
      "gen_method": "theirs"
    },
    "features": {
      "unified": false
    }
  },
  "base_overrides": {},
  "ablations": [
    {
      "name": "bulk_baseline",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/bulk_baseline",
          "wandb_name": "bulk_baseline"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/bulk_only/pipeline_ready"
        },
        "model": {},
        "features": {}
      }
    },
      {
      "name": "sc_baseline",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/sc_baseline",
          "wandb_name": "sc_baseline"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_subsample/pipeline_ready"
        },
        "model": {},
        "features": {}
      }
    },
      {
      "name": "unified_baseline",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/unified_baseline",
          "wandb_name": "unified_baseline"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready"
        },
        "model": {},
        "features": {
          "unified": true
        }
      }
    },
      {
      "name": "contrastive",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/contrastive",
          "wandb_name": "contrastive"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready"
        },
        "model": {},
        "features": {
          "unified": true,
          "contrastive_training": true
        }
      }
    },
      {
      "name": "aggregation",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/aggregation",
          "wandb_name": "aggregation"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready"
        },
        "model": {},
        "features": {
          "unified": true,
          "agg_consistency": true
        }
      }
    },
      {
      "name": "dat",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_base_comparison/dat",
          "wandb_name": "dat"
        },
        "data": {
          "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready"
        },
        "model": {},
        "features": {
          "unified": true,
          "do_dat": true,
          "dat_columns": ["modality", "assay"]
        }
      }
    }
  ],
  "downstream_tasks": [],
  "slurm": {
    "enabled": true,
    "python_executable": "python",
    "sbatch_args": [
      "--time=96:00:00",
      "--partition=gpu",
      "--ntasks-per-node=2",
      "--gres=gpu:rtx4090:2",
      "--cpus-per-task=4",
      "--mem-per-cpu=16G"
    ],
    "environment": {},
    "job_name_prefix": "ab_base"
  }
}
