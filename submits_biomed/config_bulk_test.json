{
  "trainer": {
    "gpus": 1,
    "num_workers": 1,
    "precision": "bf16-mixed",
    "strategy": "auto",
    "epochs": 1,
    "epoch_size": 1,
    "seed": 0,
    "val_check_interval": 0.5,
    "log_interval": 50,
    "save_dir": "${work}/outputs/save_CFF/dummy_bulk"

  },
  "data": {
    "train_path": "/cluster/work/boeva/rquiles/data/bulk_only/pipeline_ready",
    "conditions": ["tissue_general", "assay"],
    "zero_percentages": [0.2, 0.4, 0.6],
    "trunc_by_sample": true,
    "loss": "mse",
    "training_tasks": "pcpt"
  },

  "model": {
    "nlayers": 3,
    "nheads": 4,
    "embsize": 64,
    "d_hid": 256,
    "lr": 0.0001,
    "warmup_ratio_or_step": 10000,
    "max_seq_len": 600,
    "batch_size": 32
  },
  
  "features": {
    "do_mvc": true,
    "where_condition": "end",
    "gen_method": "theirs"
  }
}