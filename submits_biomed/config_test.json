{
  "trainer": {
    "gpus": 1,
    "num_workers": 1,
    "precision": "bf16-mixed",
    "strategy": "auto",
    "epochs": 1,
    "seed": 0,
    "val_check_interval": 0.5,
    "log_interval": 1,
    "save_dir": "${work}/outputs/save_CFF/dummy_test",
    "ckpt_every_n_steps": 5,
    "resume_from_checkpoint": "last"
  },
  "data": {
    "train_path": "/cluster/work/boeva/rquiles/data/cellxgene_bulk/pipeline_ready",
    "conditions": ["tissue_general", "assay"],
    "zero_percentages": [0.2, 0.4, 0.6],
    "bulk_ratio": 0.6,
    "pb_ratio": 0.3,
    "n_sc_per_pseudobulk": 5,
    "pb_group_column": "tissue_general",
    "trunc_by_sample": true,
    "balanced_sampler": true,
    "balanced_labels": ["tissue_general", "assay"]
  },

  "model": {
    "nlayers": 3,
    "nheads": 4,
    "embsize": 64,
    "d_hid": 256,
    "lr": 0.0001,
    "warmup_ratio_or_step": 10000,
    "max_seq_len": 600,
    "batch_size": 32,
    "input_style": "binned",
    "loss": "mse",
    "training_tasks": "both",
    "do_mvc": true,
    "where_condition": "none",
    "gen_method": "theirs"
  },
  
  "features": {
    "unified": true,
    "contrastive_training": true,
    "do_dat": true,
    "dat_columns": ["modality", "assay"]
  }
}
