{
  "trainer": {
    "gpus": 1,
    "num_workers": 1,
    "precision": "bf16-mixed",
    "strategy": "auto",
    "epochs": 1,
    "seed": 0,
    "val_check_interval": 0.5,
    "log_interval": 3,
    "save_dir": "${work}/outputs/save_CFF/dummy_test",
    "wandb_entity": "rquiles",
    "wandb": "test",
    "wandb_name": "zinb"
  },
  "data": {
    "train_path": "/cluster/work/boeva/rquiles/data/small_partition/pipeline_ready",
    "conditions": ["tissue_general", "assay"],
    "zero_percentages": [0.2, 0.4, 0.6],
    "bulk_ratio": 0.3,
    "pb_ratio": 0.3,
    "n_sc_per_pseudobulk": 5,
    "pb_group_column": "tissue_general",
    "trunc_by_sample": true
  },

  "model": {
    "nlayers": 3,
    "nheads": 4,
    "embsize": 64,
    "d_hid": 256,
    "lr": 0.0001,
    "warmup_ratio_or_step": 10000,
    "max_seq_len": 600,
    "batch_size": 32,
    "input_style": "log1p",
    "loss": "zinb",
    "training_tasks": "both",
    "do_mvc": true,
    "where_condition": "end",
    "gen_method": "theirs"
  },
  
  "features": {
    "noise": [0.4, 0.6]
  }
}