{
  "experiment_name": "cf_feature_ablation_v1",
  "train_entrypoint": "cancerfoundation.ablate.train_stub:train_from_config",
  "base_config": {
    "trainer": {
      "gpus": 1,
      "num_workers": 4,
      "precision": "bf16-mixed",
      "strategy": "ddp",
      "epochs": 10,
      "seed": 0,
      "val_check_interval": 0.5,
      "log_interval": 50,
      "save_dir": "./save/${SLURM_JOB_NAME}_${SLURM_JOB_ID}"
    },
    "data": {
      "train_path": "/cluster/work/boeva/rquiles/data/mixed_test/pipeline_ready",
      "conditions": ["tissue"],
      "zero_percentages": [0.2, 0.4, 0.6],
      "bulk_ratio": 0.3,
      "pb_ratio": 0.3,
      "n_sc_per_pseudobulk": 5,
      "trunc_by_sample": true,
      "loss": "mse",
      "training_tasks": "pcpt"
    },
    "model": {
      "nlayers": 3,
      "nheads": 4,
      "embsize": 64,
      "d_hid": 256,
      "lr": 0.0001,
      "warmup_ratio_or_step": 10000,
      "max_seq_len": 600,
      "batch_size": 32,
      "do_mvc": true,
      "do_dat": true,
      "contrastive": true,
      "aggregation": true
    },
    "features": {
      "unified": true,
      "do_mvc": true,
      "where_condition": "end",
      "gen_method": "theirs",
      "noise": [0.6]
    }
  },
  "base_overrides": {},
  "ablations": [
    {
      "name": "full_model",
      "overrides": {}
    },
    {
      "name": "no_mvc",
      "overrides": {
        "model": {
          "do_mvc": false
        }
      }
    },
    {
      "name": "no_dat",
      "overrides": {
        "model": {
          "do_dat": false
        }
      }
    },
    {
      "name": "no_contrastive",
      "overrides": {
        "model": {
          "contrastive": false
        }
      }
    }
  ],
  "downstream_tasks": [
    {
      "name": "dummy_celltype_cls",
      "entrypoint": "evaluate.dummy_downstream_task:run_dummy_downstream",
      "config": {
        "seed": 7,
        "task_weight": 1.0
      }
    }
  ],
  "slurm": {
    "enabled": false,
    "python_executable": "python",
    "sbatch_args": [
      "--partition=gpu",
      "--gres=gpu:1",
      "--cpus-per-task=8",
      "--mem=32G",
      "--time=04:00:00"
    ],
    "environment": {},
    "job_name_prefix": "cf_ablate"
  },
  "output_dir": "ablation_runs/cf_feature_ablation_v1",
  "dry_run": true
}
