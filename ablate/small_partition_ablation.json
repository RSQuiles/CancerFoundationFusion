{
  "experiment_name": "small_partition_ablation",
  "output_dir": "ablation_runs/small_partition",
  "dry_run": false,
  "train_entrypoint": "pretrain:main",
  "base_config": {
    "trainer": {
      "gpus": 1,
      "num_workers": 4,
      "precision": "bf16-mixed",
      "strategy": "auto",
      "epochs": 3,
      "seed": 0,
      "val_check_interval": 0.5,
      "log_interval": 50,
      "save_dir": "${work}/outputs/save_CFF/ablation_partition",
      "wandb_entity": "rquiles",
      "wandb": "ablation_small_partition",
      "compile": true
    },
    "data": {
      "train_path": "/cluster/work/boeva/rquiles/data/small_partition/pipeline_ready",
      "conditions": ["tissue_general", "assay"],
      "zero_percentages": [0.2, 0.4, 0.6],
      "bulk_ratio": 0.3,
      "pb_ratio": 0.3,
      "n_sc_per_pseudobulk": 5,
      "pb_group_column": "tissue_general",
      "trunc_by_sample": true,
      "balanced_sampler": "separate",
      "balanced_labels": ["tissue_general", "assay"]
    },
    "model": {
      "nlayers": 6,
      "nheads": 8,
      "embsize": 128,
      "d_hid": 256,
      "lr": 0.0001,
      "warmup_ratio_or_step": 10000,
      "max_seq_len": 600,
      "batch_size": 32,
      "input_style": "binned",
      "loss": "mse",
      "training_tasks": "both",
      "do_mvc": true,
      "where_condition": "end",
      "gen_method": "theirs"
    },
    "features": {
      "unified": false
    }
  },
  "base_overrides": {},
  "ablations": [
    {
      "name": "base_model",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/base",
          "wandb_name": "base_model"
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "zinb_reconstruction",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/zinb_rec",
          "wandb_name": "zinb"
        },
        "data": {},
        "model": {
          "loss": "zinb"
        },
        "features": {}
      }
    },
    {
      "name": "denoise_zinb",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/denoise_zinb",
          "wandb_name": "denoise_zinb"
        },
        "data": {},
        "model": {
          "input_style": "log1p",
          "loss": "zinb"
        },
        "features": {
          "noise": [0.4, 0.6]
        }
      }
    },
    {
      "name": "contrastive",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/contrastive",
          "wandb_name": "contrastive"
        },
        "data": {},
        "model": {},
        "features": {
          "unified": true,
          "contrastive_training": true
        }
      }
    },
    {
      "name": "agg_contrastive",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/agg_contrastive_denoise_zinb",
          "wandb_name": "agg_contrastive"
        },
        "data": {},
        "model": {},
        "features": {
          "unified": true,
          "contrastive_training": true,
          "agg_consistency": true
        }
      }
    },
    {
      "name": "dat_agg_contrastive_denoise_zinb",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/dat_agg_contrastive_denoise_zinb",
          "wandb_name": "dat_agg_contrastive_denoise_zinb"
        },
        "data": {},
        "model": {
          "input_style": "log1p",
          "loss": "zinb"
        },
        "features": {
          "unified": true,
          "contrastive_training": true,
          "agg_consistency": true,
          "noise": [0.4, 0.6],
          "do_dat": true,
          "dat_columns": ["modality", "assay"]
        }
      }
    }
  ],
  "downstream_tasks": [
    {
      "name": "cancer_type_annotation",
      "entrypoint": "evaluate.finetune.run_downstream_task:main",
      "config": "/cluster/work/boeva/rquiles/CancerFoundationFusion/evaluate/finetune/configs/cancer_annot_config.yaml"
    },
    {
      "name": "survival_prediction",
      "entrypoint": "evaluate.finetune.run_downstream_task:main",
      "config": "/cluster/work/boeva/rquiles/CancerFoundationFusion/evaluate/finetune/configs/survival_pred_config.yaml"
    }
  ],
  "slurm": {
    "enabled": true,
    "python_executable": "python",
    "sbatch_args": [
      "--time=48:00:00",
      "--partition=gpu",
      "--ntasks-per-node=1",
      "--gres=gpu:rtx4090:1",
      "--cpus-per-task=4",
      "--mem-per-cpu=16G"
    ],
    "environment": {},
    "job_name_prefix": "ab_small_part"
  }
}
