{
  "experiment_name": "small_partition_ablation",
  "output_dir": "ablation_runs/small_partition",
  "dry_run": false,
  "train_entrypoint": "pretrain:main",
  "base_config": {
    "trainer": {
      "gpus": 1,
      "num_workers": 1,
      "precision": "bf16-mixed",
      "strategy": "auto",
      "epochs": 1,
      "epoch_size": 1,
      "seed": 0,
      "val_check_interval": 0.5,
      "log_interval": 50,
      "save_dir": "${work}/outputs/save_CFF/ablation_partition"
    },
    "data": {
      "train_path": "/cluster/work/boeva/rquiles/data/small_partition/pipeline_ready",
      "conditions": ["tissue_general", "assay"],
      "zero_percentages": [0.2, 0.4, 0.6],
      "bulk_ratio": 0.5,
      "pb_ratio": 0.5,
      "n_sc_per_pseudobulk": 5,
      "pb_group_column": "tissue_general",
      "trunc_by_sample": true
    },
    "model": {
      "nlayers": 3,
      "nheads": 4,
      "embsize": 64,
      "d_hid": 256,
      "lr": 0.0001,
      "warmup_ratio_or_step": 10000,
      "max_seq_len": 600,
      "batch_size": 32,
      "input_style": "log1p",
      "loss": "zinb",
      "training_tasks": "both",
      "do_mvc": true,
      "where_condition": "end",
      "gen_method": "theirs"
    },
    "features": {
      "unified": true,
      "contrastive_training": true,
      "agg_consistency": true,
      "balanced_sampler": "separate",
      "balanced_labels": ["tissue_general", "assay"],
      "noise": [0.6],
      "esm_emb": true,
      "esm_emb_path": "/cluster/work/boeva/rquiles/data/esm3_homo_emb.parquet"
    }
  },
  "base_overrides": {},
  "ablations": [
    {
      "name": "full_model",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_partition/full"
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "1",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_test/..."
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "2",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_test/..."
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "3",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_test/..."
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "4",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_test/..."
        },
        "data": {},
        "model": {},
        "features": {}
      }
    },
    {
      "name": "5",
      "overrides": {
        "trainer": {
          "save_dir": "${work}/outputs/save_CFF/ablation_test/..."
        },
        "data": {},
        "model": {},
        "features": {}
      }
    }
  ],
  "downstream_tasks": [
    {
      "name": "cancer_type_annotation",
      "entrypoint": "evaluate.finetune.run_downstream_task:main",
      "config": "/cluster/work/boeva/rquiles/CancerFoundationFusion/evaluate/finetune/configs/cancer_annot_config.yaml"
    },
    {
      "name": "deconvolution",
      "entrypoint": "evaluate.finetune.run_downstream_task:main",
      "config": "/cluster/work/boeva/rquiles/CancerFoundationFusion/evaluate/finetune/configs/deconv_config.yaml"
    },
    {
      "name": "survival_prediction",
      "entrypoint": "evaluate.finetune.run_downstream_task:main",
      "config": "/cluster/work/boeva/rquiles/CancerFoundationFusion/evaluate/finetune/configs/survival_pred_config.yaml"
    }
  ],
  "slurm": {
    "enabled": false,
    "python_executable": "python",
    "sbatch_args": [
      "--time=24:00:00",
      "--partition=gpu",
      "--ntasks-per-node=2",
      "--gres=gpu:rtx4090:2",
      "--cpus-per-task=4",
      "--mem-per-cpu=16G"
    ],
    "environment": {},
    "job_name_prefix": "ab_small_part"
  }
}
